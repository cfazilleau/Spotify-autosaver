# ---------------------------------------------------------------------------
# Spotify app (required)
# ---------------------------------------------------------------------------
# Create an app at https://developer.spotify.com/dashboard, enable "Web API",
# and copy the Client ID here. No client secret is needed — accounts authorize
# through the PKCE web app (docs/index.html) and tokens refresh with the client
# id alone.
SPOTIPY_CLIENT_ID=your_client_id_here

# Must exactly match the redirect URI registered in the dashboard AND the URL
# where the web app is hosted (e.g. your GitHub Pages URL).
SPOTIPY_REDIRECT_URI=https://your-username.github.io/Spotify-autosaver/

# ---------------------------------------------------------------------------
# Accounts to sync (required)
# ---------------------------------------------------------------------------
# Path to a JSON file listing accounts and their refresh tokens (see
# users.example.json). Generate tokens with the PKCE web app. In Docker this is
# mounted into the container.
# AUTOSAVER_USERS_FILE=users.json

# ---------------------------------------------------------------------------
# What to sync (optional — sensible defaults shown)
# ---------------------------------------------------------------------------
# How many of your most recent liked songs to mirror.
# AUTOSAVER_TRACK_COUNT=100

# Target an existing playlist by id. If unset, the playlist is looked up by
# name and created automatically if it does not exist.
# AUTOSAVER_PLAYLIST_ID=

# Name used to find/create the playlist (ignored when PLAYLIST_ID is set).
# AUTOSAVER_PLAYLIST_NAME=Liked Songs (Latest 100)

# Make the auto-created playlist public (true/false).
# AUTOSAVER_PLAYLIST_PUBLIC=false

# Description for the auto-created playlist.
# AUTOSAVER_PLAYLIST_DESCRIPTION=Automatically maintained by Spotify Autosaver — mirrors my most recently liked songs.

# ---------------------------------------------------------------------------
# Continuous mode (optional)
# ---------------------------------------------------------------------------
# Seconds between polls when running `spotify-autosaver run`. Each poll is a
# single cheap API call that only triggers a full sync when your liked songs
# actually change, so short intervals are fine — 10 is perfectly safe.
# AUTOSAVER_INTERVAL_SECONDS=3600
