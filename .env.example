# ---------------------------------------------------------------------------
# Spotify app credentials (required)
# ---------------------------------------------------------------------------
# Create an app at https://developer.spotify.com/dashboard and copy the
# Client ID / Client Secret here. Add the redirect URI below to the app's
# "Redirect URIs" list in the dashboard settings.
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ---------------------------------------------------------------------------
# Headless auth (optional)
# ---------------------------------------------------------------------------
# For servers / containers / CI where no browser is available. Generate this
# once by running `spotify-autosaver auth` on a machine with a browser, then
# store the printed value here (or as a secret). When set, interactive login
# and the local .cache file are bypassed entirely.
#
# NOTE: This is the SINGLE-account shortcut. To sync several accounts (you +
# friends) from one deployment, leave this unset and list each account's token
# in a users file instead (see AUTOSAVER_USERS_FILE below). The users file, when
# present, takes precedence over this variable.
# SPOTIFY_REFRESH_TOKEN=

# Path to a JSON file listing accounts to sync (see users.example.json).
# Defaults to users.json in the working directory. In Docker this is mounted.
# AUTOSAVER_USERS_FILE=users.json

# Where spotipy caches tokens during interactive auth (ignored if a refresh
# token is provided).
# AUTOSAVER_CACHE_PATH=.cache

# ---------------------------------------------------------------------------
# What to sync (optional — sensible defaults shown)
# ---------------------------------------------------------------------------
# How many of your most recent liked songs to mirror.
# AUTOSAVER_TRACK_COUNT=100

# Target an existing playlist by id. If unset, the playlist is looked up by
# name and created automatically if it does not exist.
# AUTOSAVER_PLAYLIST_ID=

# Name used to find/create the playlist (ignored when PLAYLIST_ID is set).
# AUTOSAVER_PLAYLIST_NAME=Liked Songs (Latest 100)

# Make the auto-created playlist public (true/false).
# AUTOSAVER_PLAYLIST_PUBLIC=false

# Description for the auto-created playlist.
# AUTOSAVER_PLAYLIST_DESCRIPTION=Automatically maintained by Spotify Autosaver — mirrors my most recently liked songs.

# ---------------------------------------------------------------------------
# Continuous mode (optional)
# ---------------------------------------------------------------------------
# Seconds between polls when running `spotify-autosaver run`. Each poll is a
# single cheap API call that only triggers a full sync when your liked songs
# actually change, so short intervals are fine — 10 is perfectly safe.
# AUTOSAVER_INTERVAL_SECONDS=3600
